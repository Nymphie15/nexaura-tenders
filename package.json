{
  "name": "web-client",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:coverage:watch": "vitest --coverage",
    "test:unit": "vitest run tests/unit",
    "test:ui-components": "vitest run src/components/ui/__tests__",
    "test:ui-components:watch": "vitest src/components/ui/__tests__",
    "test:ui-components:coverage": "vitest run --coverage src/components/ui/__tests__",
    "test:forms": "vitest run src/__tests__/components/forms",
    "test:forms:watch": "vitest src/__tests__/components/forms",
    "test:forms:coverage": "vitest run --coverage src/__tests__/components/forms",
    "test:realtime": "vitest run src/__tests__/realtime",
    "test:realtime:watch": "vitest watch src/__tests__/realtime",
    "test:realtime:coverage": "vitest run --coverage src/__tests__/realtime",
    "test:realtime:ui": "vitest --ui src/__tests__/realtime",
    "test:error-handling": "vitest run src/__tests__/error-handling",
    "test:error-handling:watch": "vitest watch src/__tests__/error-handling",
    "test:error-handling:coverage": "vitest run --coverage src/__tests__/error-handling",
    "test:error-handling:ui": "vitest --ui src/__tests__/error-handling",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:debug": "vitest --inspect-brk",
    "test:typecheck": "vitest typecheck",
    "test:ci": "vitest run --reporter=junit --reporter=verbose"
  },
